{
  "name": "bigos",
  "version": "1.0.0",
  "description": "BigOs - A fast, Unix-styled Node.js web browser with full GUI and CLI modes",
  "main": "main.js",
  "bin": {
    "bigos": "bin/bigbrowser.js",
    "bigos-gui": "bin/bigbrowser-gui.js"
  },
  "scripts": {
    "start": "electron .",
    "cli": "node bin/bigbrowser.js",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["bigos", "browser", "electron", "cli", "unix", "freebsd", "react", "node"],
  "author": "BigOs",
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "cheerio": "^1.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.0"
  },
  "build": {
    "appId": "com.bigos.app",
    "productName": "BigOs",
    "copyright": "MIT",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "verifyUpdateCodeSignature": false,
      "target": [
        { "target": "dir",  "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ]
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    }
  }
}
