<Window x:Class="UnixBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Unix Browser" Height="720" Width="1280"
        Background="#1a1a1a" Foreground="#e0e0e0"
        FontFamily="Courier New" FontSize="11"
        Loaded="Window_Loaded"
        WindowStyle="None"
        AllowsTransparency="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#0d0d0d" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <TextBlock Text="Unix Browser — Web Terminal" VerticalAlignment="Center" Foreground="#00ff00" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="MinimizeBtn" Width="30" Height="30" Background="Transparent" Foreground="#e0e0e0" 
                            Content="−" FontSize="16" Click="MinimizeBtn_Click" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="MaximizeBtn" Width="30" Height="30" Background="Transparent" Foreground="#e0e0e0" 
                            Content="□" FontSize="14" Click="MaximizeBtn_Click" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0"/>
                    <Button x:Name="CloseBtn" Width="30" Height="30" Background="Transparent" Foreground="#ff6b6b" 
                            Content="✕" FontSize="16" Click="CloseBtn_Click" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Navigation Bar -->
        <Border Grid.Row="1" Background="#242424" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0" Background="#2a2a2a" Foreground="#00ff00" 
                        Content="←" FontSize="14" BorderThickness="1" BorderBrush="#444444" Cursor="Hand"/>
                <Button x:Name="ForwardButton" Grid.Column="1" Background="#2a2a2a" Foreground="#00ff00" 
                        Content="→" FontSize="14" BorderThickness="1" BorderBrush="#444444" Margin="5,0,0,0" Cursor="Hand"/>
                <Button x:Name="RefreshButton" Grid.Column="2" Background="#2a2a2a" Foreground="#00ff00" 
                        Content="⟳" FontSize="14" BorderThickness="1" BorderBrush="#444444" Margin="5,0,0,0" Cursor="Hand"/>
                <Button x:Name="HomeButton" Grid.Column="3" Background="#2a2a2a" Foreground="#00ff00" 
                        Content="⌂" FontSize="14" BorderThickness="1" BorderBrush="#444444" Margin="5,0,0,0" Cursor="Hand"/>

                <TextBox x:Name="AddressBar" Grid.Column="4" Background="#1a1a1a" Foreground="#00ff00"
                         FontFamily="Courier New" FontSize="12"
                         BorderThickness="1" BorderBrush="#555555" Padding="10,6" Margin="10,0,0,0"
                         Height="34" VerticalContentAlignment="Center" Text="about:blank"/>
            </Grid>
        </Border>

        <!-- WebView Container -->
        <Border Grid.Row="2" Background="#0d0d0d" BorderBrush="#333333" BorderThickness="1">
            <Grid x:Name="WebViewContainer" Background="#1a1a1a"/>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#1a1a1a" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <Grid Margin="10,5">
                <TextBlock x:Name="StatusText" Foreground="#888888" Text="Ready" FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Foreground="#888888" Text="[PWA Ready]" FontSize="10" Margin="0,0,15,0"/>
                    <TextBlock Foreground="#888888" Text="[Service Worker: Active]" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
